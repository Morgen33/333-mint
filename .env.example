# Helius RPC (recommended for mint) — get a key at https://helius.dev
# Copy to .env and set your key so the mint page uses it.
VITE_RPC_URL=https://mainnet.helius-rpc.com/?api-key=8b703cd2-59a1-43a9-8c9d-e2054a7bff4d

# Phantom Portal App ID — use this app in https://phantom.app/portal and verify your domain
# so Phantom does not show "new domain" / scam warnings. Add 333landingpage.vercel.app to allowed origins.
VITE_PHANTOM_APP_ID=85950ca1-bdc2-421a-a43a-d4aa9c90afb9
